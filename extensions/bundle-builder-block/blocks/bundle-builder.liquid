{% comment %}
  Bundle Builder App Block
  Renders a flavor/option picker for bundle products.
  Place this block on a product page via the theme editor.
{% endcomment %}

<div
  id="bundle-builder-app"
  data-product-id="{{ product.id }}"
  data-proxy-base="/apps/bundle-builder"
  data-heading="{{ block.settings.heading | escape }}"
  style="display: none;"
>
  <div class="bb-loading">
    <p>Loading bundle options...</p>
  </div>
</div>

<noscript>
  <div class="bb-noscript">
    <p>JavaScript is required to use the bundle builder. Please enable JavaScript in your browser.</p>
  </div>
</noscript>

{{ 'bundle-builder.css' | asset_url | stylesheet_tag }}
<script src="{{ 'bundle-builder.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Bundle Selector",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Build Your Bundle"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Grid columns",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "color",
      "id": "selected_color",
      "label": "Selected border color",
      "default": "#008060"
    },
    {
      "type": "color",
      "id": "counter_bg_color",
      "label": "Counter background color",
      "default": "#008060"
    }
  ]
}
{% endschema %}
